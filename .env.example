# NeonPanda PWA — variables de entorno
#
# Copiar a `.env` y rellenar con los valores reales del entorno local.
# Estas variables se leen en build-time via scripts/build-env.ts y se
# inyectan en src/environments/environment.ts.
#
# NUNCA committear `.env` — solo `.env.example` (sin secretos reales).

# URL base de API-FAKE, incluye el prefijo de version.
# Dev local (Docker): http://localhost:2004/v3
API_BASE_URL=http://localhost:2004/v3

# API key estatica que identifica a esta app cliente.
# Validada por middleware en API-FAKE en TODOS los endpoints.
# Solicitar valor al equipo backend para cada entorno.
API_KEY=<solicitar-al-backend>


# Version SemVer mostrada al usuario en el footer y el modal de update.
# Bumpear manualmente en cada deploy (MAJOR.MINOR.PATCH).
# Reglas:
#   - PATCH (1.0.x): fixes invisibles para el alumno.
#   - MINOR (1.x.0): features visibles.
#   - MAJOR (x.0.0): cambios incompatibles.
# Nota: el banner "Hay version nueva" lo dispara el hash del bundle (Angular SW),
# NO esta variable. Esta variable solo controla el TEXTO mostrado al usuario.
# Si cambias el codigo pero NO bumpeas esta var, el modal mostrara "X -> X".
APP_VERSION=1.0.0

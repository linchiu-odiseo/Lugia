{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.json",
          "/*.css",
          "/*.js",
          "/ico-16.ico",
          "/ico-32.ico",
          "/ico-48.ico",
          "/icon-180.png",
          "/icon-192.png",
          "/icon-384.png",
          "/icon-512.png"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/media/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|ico|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
